# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Environment variables (NEVER commit secrets) ─────────────────────────────
.env
.env.local
.env.*.local
# Keep the example template
!.env.example

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
out/

# ─── TypeScript compiled output ───────────────────────────────────────────────
*.js.map
*.d.ts.map

# ─── Prisma generated client ──────────────────────────────────────────────────
# Generated at build time — do not commit
backend/node_modules/.prisma/
# Keep schema and migrations
!backend/prisma/schema.prisma
!backend/prisma/migrations/

# ─── Uploaded files ───────────────────────────────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── OS / editor artifacts ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── VS Code (keep shared settings, ignore personal) ─────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.tsbuildinfo
.cache/
.parcel-cache/
